menu "USBIP Configuration"

config USBIP_ENABLE_WINUSB
    bool "Enable WinUSB mode"
    default y
    help
        Enable WinUSB mode for DAPLink.
        WinUSB mode provides better performance with 512-byte packet size.
        Disable this for HID mode, which is required for Keil MDK compatibility.

choice USBIP_USB_SPEED
    prompt "USB Speed"
    default USBIP_USB_SPEED_2_0
    help
        Select USB speed mode.
        USB 2.0 uses 512-byte endpoint size.
        USB 3.0 uses 1024-byte endpoint size.

    config USBIP_USB_SPEED_2_0
        bool "USB 2.0"

    config USBIP_USB_SPEED_3_0
        bool "USB 3.0"
endchoice

config USBIP_ENABLE_USB_3_0
    bool
    default y if USBIP_USB_SPEED_3_0
    default n if USBIP_USB_SPEED_2_0

config USBIP_ENDPOINT_SIZE
    int
    default 1024 if USBIP_ENABLE_USB_3_0
    default 512 if !USBIP_ENABLE_USB_3_0

endmenu